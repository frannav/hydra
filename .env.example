# Shared environment variables for Docker or infrastructure.
# Copy to .env and fill in real values. Never commit .env.

# API model provider key (e.g. OpenAI, Anthropic)
MODEL_API_KEY=

# Langfuse tracing
LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_BASE_URL=

# Database URL (local development)
DATABASE_URL=postgresql://user:password@localhost:5432/hydra
